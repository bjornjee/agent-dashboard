{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bjornjee/agent-dashboard/schema/agent-state.schema.json",
  "title": "Agent State",
  "description": "Per-agent state file written by adapters and read by the agent-dashboard TUI.",
  "type": "object",
  "required": ["target", "tmux_pane_id", "session_id", "state", "updated_at"],
  "properties": {
    "target": {
      "type": "string",
      "description": "Tmux target string, e.g. 'session:window.pane'"
    },
    "tmux_pane_id": {
      "type": "string",
      "description": "Immutable tmux pane ID in %N format, e.g. '%5'"
    },
    "session": {
      "type": "string",
      "description": "Tmux session name"
    },
    "window": {
      "type": "integer",
      "description": "Tmux window index"
    },
    "pane": {
      "type": "integer",
      "description": "Tmux pane index within window"
    },
    "state": {
      "type": "string",
      "enum": ["permission", "plan", "question", "error", "running", "idle_prompt", "done", "pr", "merged"],
      "description": "Current agent state"
    },
    "cwd": {
      "type": "string",
      "description": "Agent's working directory"
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier (UUID)"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the agent session started"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last state update"
    },
    "model": {
      "type": "string",
      "description": "Model identifier, e.g. 'claude-opus-4-6'"
    },
    "permission_mode": {
      "type": "string",
      "description": "Agent permission mode, e.g. 'default', 'bypassPermissions'"
    },
    "current_tool": {
      "type": "string",
      "description": "Name of tool currently being executed"
    },
    "last_hook_event": {
      "type": "string",
      "description": "Name of the last hook event that triggered a state update"
    },
    "last_message_preview": {
      "type": ["string", "null"],
      "description": "Truncated preview of the agent's last assistant message"
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of changed files with prefix: '+' added, '~' modified, '-' deleted"
    },
    "subagent_count": {
      "type": "integer",
      "description": "Number of currently active subagents"
    },
    "worktree_cwd": {
      "type": "string",
      "description": "Git worktree directory if the agent is working in a worktree"
    },
    "pinned_state": {
      "type": "string",
      "description": "Dashboard-set state override that survives hook updates"
    },
    "branch": {
      "type": "string",
      "description": "Current git branch name"
    },
    "pr_url": {
      "type": "string",
      "description": "GitHub pull request URL when state is pr or merged"
    }
  },
  "additionalProperties": true
}
