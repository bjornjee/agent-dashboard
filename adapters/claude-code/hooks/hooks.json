{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Register agent in dashboard on session start"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/warn-destructive.js\""
          }
        ],
        "description": "Block destructive shell commands (rm -rf, git reset --hard, DROP TABLE, etc.)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/block-main-commit.js\""
          }
        ],
        "description": "Block git commit on main/master — require a feature branch"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/codex-write-gate.js\""
          }
        ],
        "description": "Block codex-companion task without --write (prevents read-only sandbox)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-fast.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Fast state sync for dashboard (state, permission_mode, current_tool)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/codex-delegation-gate.js\""
          }
        ],
        "description": "Nudge Codex delegation after plan approval (worktree + codex available)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/commit-lint.js\""
          }
        ],
        "description": "Validate conventional commit message format on git commit"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/test-gate.js\""
          }
        ],
        "description": "Block git commit unless make test passes (set SKIP_TEST_GATE=1 to bypass)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pr-detect.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Detect gh pr create/merge and update agent state to pr/merged"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-fast.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Fast state sync for dashboard"
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-fast.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Instant needs-attention detection for dashboard"
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Track subagent spawn in dashboard"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Track subagent completion in dashboard"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Desktop notification + agent state reporting; Blow sound when AskUserQuestion or ExitPlanMode detected"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/mermaid-extractor.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Extract mermaid diagrams from assistant messages into ~/.agent-dashboard/diagrams/"
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/desktop-notify.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Blow sound on permission prompt, idle prompt, or elicitation dialog"
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/desktop-notify.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Blow sound on rate limit errors"
      }
    ]
  }
}
