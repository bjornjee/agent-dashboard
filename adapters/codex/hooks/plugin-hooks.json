{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-reporter.js\"",
            "timeout": 5000
          }
        ],
        "description": "Register Codex agent in dashboard on session start"
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-reporter.js\"",
            "timeout": 5000
          }
        ],
        "description": "Track Codex subagent start in dashboard"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-reporter.js\"",
            "timeout": 5000
          }
        ],
        "description": "Track Codex subagent stop in dashboard"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/warn-destructive.js\"",
            "timeout": 5000
          }
        ],
        "description": "Block destructive shell commands (rm -rf, git reset --hard, DROP TABLE, etc.)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/block-main-commit.js\"",
            "timeout": 5000
          }
        ],
        "description": "Block git commit on main/master — require a feature branch"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-fast.js\"",
            "timeout": 5000
          }
        ],
        "description": "Fast Codex state sync for dashboard before tool use"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-fast.js\"",
            "timeout": 5000
          }
        ],
        "description": "Fast Codex state sync for dashboard after tool use"
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-fast.js\"",
            "timeout": 5000
          }
        ],
        "description": "Instant Codex needs-attention detection for dashboard"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/agent-state-reporter.js\"",
            "timeout": 5000
          }
        ],
        "description": "Final Codex state sync for dashboard"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/pr-skill-detect.js\"",
            "timeout": 5000
          }
        ],
        "description": "Detect $agent-dashboard:pr skill invocation and pin agent state to pr"
      }
    ]
  }
}
